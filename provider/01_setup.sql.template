-- ============================================================
-- IDEAL ARCHITECTURE POC — Provider Setup
-- Phase 3: Multi-tenant data with Row Access Policy
-- Creates: Database, schema, multi-tenant sample data,
--          secure view, RAP, semantic view
-- ============================================================

USE ROLE ACCOUNTADMIN;
USE WAREHOUSE ${WAREHOUSE};

-- New database for the ideal architecture PoC
CREATE DATABASE IF NOT EXISTS IDEAL_AGENT_POC;
CREATE SCHEMA IF NOT EXISTS IDEAL_AGENT_POC.DATA;

-- Multi-tenant sales table (Phase 3: tenant_id maps to account locator)
CREATE OR REPLACE TABLE IDEAL_AGENT_POC.DATA.SALES (
    sale_id INT,
    tenant_id VARCHAR,
    sale_date DATE,
    product_name VARCHAR,
    category VARCHAR,
    quantity INT,
    unit_price DECIMAL(10,2),
    total_amount DECIMAL(10,2),
    region VARCHAR,
    salesperson VARCHAR
);

