-- Secure view exposes all columns EXCEPT tenant_id (RAP filters transparently)
CREATE OR REPLACE SECURE VIEW IDEAL_AGENT_POC.DATA.V_SALES AS
SELECT sale_id, sale_date, product_name, category, quantity, unit_price,
       total_amount, region, salesperson
FROM IDEAL_AGENT_POC.DATA.SALES;

-- ============================================================
-- Row Access Policy: filter rows by tenant account
-- CURRENT_ACCOUNT() returns the account locator of the caller.
-- Each tenant only sees rows where tenant_id matches their account.
-- ============================================================
CREATE OR REPLACE ROW ACCESS POLICY IDEAL_AGENT_POC.DATA.TENANT_RAP
  AS (tenant_id VARCHAR) RETURNS BOOLEAN ->
    tenant_id = CURRENT_ACCOUNT();

-- Attach RAP to the BASE TABLE (not the view — RAPs on secure views
-- require the policy column to exist in the view's SELECT list, but
-- we deliberately exclude tenant_id from V_SALES).
ALTER TABLE IDEAL_AGENT_POC.DATA.SALES
  ADD ROW ACCESS POLICY IDEAL_AGENT_POC.DATA.TENANT_RAP ON (tenant_id);

-- ============================================================
-- Semantic view over the sales data (must live in provider DB,
-- not inside the native app, so SEMANTIC_VIEW() function works)
-- ============================================================
CREATE OR REPLACE SEMANTIC VIEW IDEAL_AGENT_POC.DATA.SALES_SEMANTIC_VIEW
  TABLES (
    sales AS IDEAL_AGENT_POC.DATA.V_SALES
      PRIMARY KEY (sale_id)
      COMMENT = 'Sales transactions with product, region, and salesperson details'
  )
  DIMENSIONS (
    sales.sale_id AS sale_id
      COMMENT = 'Unique identifier for the sale',
    sales.sale_date AS sale_date
      COMMENT = 'Date when the sale occurred',
    sales.product_name AS product_name
      COMMENT = 'Name of the product sold',
    sales.category AS category
      COMMENT = 'Product category (Electronics or Services)',
    sales.region AS region
      COMMENT = 'Sales region (North, South, East, West)',
    sales.salesperson AS salesperson
      COMMENT = 'Name of the salesperson'
  )
  METRICS (
    sales.total_quantity AS SUM(quantity)
      COMMENT = 'Total quantity of items sold',
    sales.total_revenue AS SUM(total_amount)
      COMMENT = 'Total sales revenue in dollars',
    sales.avg_price AS AVG(unit_price)
      COMMENT = 'Average price per unit in dollars',
    sales.num_sales AS COUNT(sale_id)
      COMMENT = 'Number of sales transactions'
  );
