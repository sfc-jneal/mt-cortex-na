# Snowflake connection & account config
# Copy to .env and fill in your values, then run: make render

# Provider account locator (run: SELECT CURRENT_ACCOUNT())
PROVIDER_ACCOUNT=YOUR_PROVIDER_ACCOUNT_LOCATOR

# Consumer account locator
CONSUMER_ACCOUNT=YOUR_CONSUMER_ACCOUNT_LOCATOR

# Warehouse name
WAREHOUSE=COMPUTE_WH

# Snowflake CLI connection name (from ~/.snowflake/connections.toml)
SNOW_CONNECTION=your_connection_name

# Application name (used in setup.sql for fully-qualified agent references)
APP_NAME=IDEAL_AGENT_APP
